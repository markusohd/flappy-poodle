# ── PDAX API credentials ───────────────────────────────────────────────────────
# Get these from PDAX by emailing institutions@pdax.ph
PDAX_API_KEY=your_api_key_here
PDAX_SECRET_KEY=your_secret_key_here

# ── Environment ────────────────────────────────────────────────────────────────
# Set to "false" to trade on the live exchange (REAL MONEY)
# Leave as "true" to use the PDAX sandbox (safe for testing)
PDAX_SANDBOX=true

# ── Database path (optional) ───────────────────────────────────────────────────
# PDAX_DB_PATH=logs/market_data.db
